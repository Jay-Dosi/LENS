# ============================================
# ESG Claim Verification Assistant
# ============================================

# ============================================
# IBM watsonx.ai (REQUIRED)
# ============================================
# Get your API key from: https://cloud.ibm.com/iam/apikeys
IBM_CLOUD_API_KEY=your_ibm_cloud_api_key_here

# Get your project ID from: https://dataplatform.cloud.ibm.com/wx/home
IBM_WATSONX_PROJECT_ID=your_watsonx_project_id_here

# watsonx.ai endpoint (default: US South)
WATSONX_URL=https://us-south.ml.cloud.ibm.com

# Models to use
# Using ibm/granite-3-8b-instruct for both extraction and explanation
# This is the closest available IBM Granite instruction-tuned model
# (granite-13b-instruct-v2 is not available in this environment)
WATSONX_EXTRACTION_MODEL=ibm/granite-3-8b-instruct
WATSONX_EXPLANATION_MODEL=ibm/granite-3-8b-instruct

# ============================================
# IBM Watson NLU (REQUIRED)
# ============================================
# Get your API key from: https://cloud.ibm.com/iam/apikeys
WATSON_NLU_API_KEY=your_watson_nlu_api_key_here

# Watson NLU endpoint (default: US South)
WATSON_NLU_URL=https://api.us-south.natural-language-understanding.watson.cloud.ibm.com

# ============================================
# Storage Configuration - ChromaDB
# ============================================
# Storage mode: "memory" (stateless) or "persistent" (local disk)
STORAGE_MODE=memory

# Only used if STORAGE_MODE=persistent
STORAGE_PERSIST_DIRECTORY=./chroma_storage

# Session timeout in minutes
SESSION_TIMEOUT_MINUTES=60

# ============================================
# NLU Configuration
# ============================================
# Watson NLU is configured above - no additional settings needed

# ============================================
# External APIs
# ============================================
# OpenWeatherMap Air Pollution API (OPTIONAL - will use demo data if not configured)
# Get your FREE API key from: https://openweathermap.org/api
# Sign up at: https://home.openweathermap.org/users/sign_up
# Free tier: 1,000 calls/day (more than enough for this application)
# Used for air quality monitoring near facilities
OPENWEATHERMAP_API_KEY=your_openweathermap_api_key_here

# Google News RSS (No key required - public RSS feed)
# Used for news article analysis related to facilities
# Rate limited to 2 seconds between requests to be respectful

# ============================================
# Application Settings
# ============================================
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50
ALLOWED_EXTENSIONS=pdf
LOG_LEVEL=INFO

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Disable ChromaDB Telemetry
ANONYMIZED_TELEMETRY=False